{
  "name": "metrobus-status-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker API for Metrobus CDMX real-time status",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy",
    "tail": "wrangler tail",
    "tail:staging": "wrangler tail --env staging",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "kv:create": "wrangler kv:namespace create METROBUS_CACHE",
    "kv:create:preview": "wrangler kv:namespace create METROBUS_CACHE --preview",
    "kv:list": "wrangler kv:namespace list"
  },
  "keywords": [
    "cloudflare-workers",
    "metrobus",
    "cdmx",
    "transit",
    "scraper"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.15",
    "wrangler": "^4.92.0"
  }
}
